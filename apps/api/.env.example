# Microsoft SQL Server Database Connection
# Format: sqlserver://host:port;database=dbname;user=username;password=password;trustServerCertificate=true
DATABASE_URL="sqlserver://127.0.0.1:1433;database=NEPSEAnalysisDB;user=sa;password=your_password;trustServerCertificate=true"

# API server configuration
PORT=4000
CORS_ORIGIN="*"

# AI API Keys (Required for ML features)
# Get API keys from project documentation or AI service providers
GROQ_API_KEY=your_groq_api_key_here
POLLENS_API_KEY=your_pollens_api_key_here

# Alternative: Local SQLite for development (not recommended for production)
# DATABASE_URL="file:./dev.db"
