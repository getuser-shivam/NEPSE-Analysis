# ============================================
# NEPSE Analysis - Environment Configuration
# ============================================

# Database (SQL Server)
DATABASE_URL="sqlserver://localhost:1433;database=nepse_analysis;user=sa;password=YourStrong@Passw0rd;trustServerCertificate=true"

# Server
PORT=3000
NODE_ENV=development

# Groq AI (Free tier - https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=500
GROQ_TEMPERATURE=0.3
ENABLE_GROQ_AI=true

# Pollinations AI (Free, no API key required)
POLLENS_BASE_URL=https://text.pollinations.ai
ENABLE_POLLENS_AI=true

# Rate Limiting
AI_RATE_LIMIT_PER_MINUTE=10
AI_RATE_LIMIT_PER_HOUR=100
AI_FALLBACK_ENABLED=true
